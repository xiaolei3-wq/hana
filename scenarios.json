    {
      "id": "taxi",
      "name_en": "Directions & Taxi",
      "name_cn": "问路和打车",
      "icon": "🚕",
      "character_role": "Passerby",
      "dialogue": [
        {
          "turn": 1,
          "role": "character",
          "zh": "你好，需要帮忙吗？",
