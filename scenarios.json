          "en": "Hello, do you need help?"
        },
        {
          "turn": 2,
          "role": "user",
          "zh": "请问，地铁站怎么走？",
          "py": "Qǐngwèn, dìtiě zhàn zěnme zǒu?",
          "en": "Excuse me, how to get to the subway?"
        },
        {
          "turn": 3,
          "role": "character",
          "zh": "一直走，然后左转。大概五分钟。",
          "py": "Yīzhí zǒu, ránhòu zuǒ zhuǎn. Dàgài wǔ fēnzhōng.",
          "en": "Go straight, turn left. About 5 min."
        },
        {
          "turn": 4,
          "role": "user",
          "zh": "谢谢！",
          "py": "Xièxie!",
          "en": "Thank you!"
        },
        {
          "turn": 5,
          "role": "character",
          "zh": "你好！去哪里？",
          "py": "Nǐ hǎo! Qù nǎlǐ?",
          "en": "Hello! Where to?",
          "speaker": "Driver"
        },
        {
          "turn": 6,
          "role": "user",
          "zh": "去天安门，谢谢。",
          "py": "Qù Tiān'ānmén, xièxie.",
          "en": "To Tiananmen, thanks.",
          "speaker": "Driver"
        },
        {
          "turn": 7,
          "role": "character",
          "zh": "好的。到了，一共三十块。",
          "py": "Hǎo de. Dào le, yígòng sānshí kuài.",
          "en": "OK. Here, 30 yuan.",
          "speaker": "Driver"
        },
        {
          "turn": 8,
          "role": "user",
          "zh": "好的，谢谢师傅！",
          "py": "Hǎo de, xièxie shīfu!",
