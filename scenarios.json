      "id": "intro",
      "name_en": "Introducing Yourself",
      "name_cn": "自我介绍",
      "icon": "👋",
      "character_role": "Friend",
      "dialogue": [
        {
          "turn": 1,
          "role": "character",
          "zh": "你好！我是小明。你叫什么名字？",
          "py": "Nǐ hǎo! Wǒ shì Xiǎo Míng. Nǐ jiào shénme míngzi?",
          "en": "Hello! I'm Xiao Ming. What's your name?"
        },
        {
          "turn": 2,
          "role": "user",
          "zh": "你好！我叫 Alex。",
          "py": "Nǐ hǎo! Wǒ jiào Alex.",
          "en": "Hello! My name is Alex."
        },
        {
          "turn": 3,
          "role": "character",
          "zh": "Alex，你好！你是哪国人？",
          "py": "Alex, nǐ hǎo! Nǐ shì nǎ guó rén?",
          "en": "Alex, hello! Where are you from?"
        },
        {
          "turn": 4,
          "role": "user",
          "zh": "我是美国人。",
          "py": "Wǒ shì Měiguó rén.",
          "en": "I am American."
        },
        {
          "turn": 5,
          "role": "character",
          "zh": "美国！你做什么工作？",
          "py": "Měiguó! Nǐ zuò shénme gōngzuò?",
          "en": "America! What do you do?"
        },
        {
          "turn": 6,
          "role": "user",
          "zh": "我是老师。很高兴认识你！",
          "py": "Wǒ shì lǎoshī. Hěn gāoxìng rènshi nǐ!",
          "en": "I'm a teacher. Nice to meet you!"
        }
      ],
      "vocab": [
