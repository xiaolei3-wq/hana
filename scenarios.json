    {
      "id": "restaurant",
      "name_en": "Ordering at a Restaurant",
      "name_cn": "在餐厅点餐",
      "icon": "🍜",
      "character_role": "Waiter",
      "dialogue": [
        {
          "turn": 1,
          "role": "character",
          "zh": "你好！欢迎光临！请问几位？",
          "py": "Nǐ hǎo! Huānyíng guānglín! Qǐngwèn jǐ wèi?",
          "en": "Hello! Welcome! How many people?"
        },
        {
          "turn": 2,
          "role": "user",
          "zh": "你好，一个人。",
          "py": "Nǐ hǎo, yī gè rén.",
          "en": "Hello, just one person."
        },
        {
          "turn": 3,
          "role": "character",
          "zh": "好的，这边请。这是菜单。",
          "py": "Hǎo de, zhè biān qǐng. Zhè shì càidān.",
          "en": "This way please. Here's the menu."
        },
        {
          "turn": 4,
          "role": "user",
          "zh": "我要一碗面。",
          "py": "Wǒ yào yī wǎn miàn.",
          "en": "I want a bowl of noodles."
        },
        {
          "turn": 5,
          "role": "character",
          "zh": "好的。要喝什么？",
          "py": "Hǎo de. Yào hē shénme?",
          "en": "OK. What would you like to drink?"
        },
        {
          "turn": 6,
          "role": "user",
          "zh": "一杯茶，谢谢。",
          "py": "Yī bēi chá, xièxie.",
          "en": "A cup of tea, thanks."
        },
        {
          "turn": 7,
          "role": "character",
          "zh": "一碗面一杯茶，一共二十五块。",
          "py": "Yī wǎn miàn yī bēi chá, yígòng èrshíwǔ kuài.",
          "en": "Noodles and tea, 25 yuan total."
        },
        {
          "turn": 8,
          "role": "user",
          "zh": "好的，买单。谢谢！",
          "py": "Hǎo de, mǎi dān. Xièxie!",
          "en": "OK, bill please. Thanks!"
